/*
 * LaMetric Time board DTS for Linux 5.15
 * Clean minimal DTS — only enables what we need.
 * Based on original firmware DTB analysis + script.fex.
 */
/dts-v1/;
#include "sun5i-a13.dtsi"
#include <dt-bindings/gpio/gpio.h>

/ {
	model = "LaMetric Time";
	compatible = "lametric,time", "allwinner,sun5i-a13";

	aliases {
		serial0 = &uart1;
	};

	chosen {
		stdout-path = "serial0:115200n8";
		bootargs = "clk_ignore_unused";
	};
};

/* AXP209 PMIC on I2C0 */
&i2c0 {
	status = "okay";

	axp209: pmic@34 {
		compatible = "x-powers,axp209";
		reg = <0x34>;
		interrupts = <0>;
	};
};

/* I2C2 for STM32 display + light sensor */
&i2c2 {
	status = "okay";
};

/* Debug UART */
&uart1 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart1_pg_pins>;
	status = "okay";
};

/* USB OTG — force peripheral/device mode */
&otg_sram {
	status = "okay";
};

&usb_otg {
	dr_mode = "peripheral";
	status = "okay";
};

&usbphy {
	usb0_id_det-gpios = <&pio 6 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
	usb0_vbus_det-gpios = <&pio 6 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
	usb1_vbus-supply = <&reg_usb1_vbus>;
	status = "okay";
};

/* EHCI/OHCI for internal USB hub (WiFi module) */
&ehci0 {
	status = "okay";
};

&ohci0 {
	status = "okay";
};

/* SD card */
&mmc0 {
	bus-width = <4>;
	status = "okay";
};

/* SPI2 for display pixel data */
&spi2 {
	pinctrl-names = "default";
	pinctrl-0 = <&spi2_pe_pins &spi2_cs0_pe_pin>;
	status = "okay";

	display@0 {
		compatible = "rohm,dh2228fv";
		reg = <0>;
		spi-max-frequency = <12000000>;
	};
};

/* WiFi power (PD22) — must be HIGH for RTL8723BU to power on */
/ {
	wifi_power: regulator-wifi {
		compatible = "regulator-fixed";
		regulator-name = "wifi-power";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&pio 3 22 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-always-on;
		regulator-boot-on;
	};

	/* USB1 host VBUS for internal WiFi hub */
	reg_usb1_vbus: regulator-usb1-vbus {
		compatible = "regulator-fixed";
		regulator-name = "usb1-vbus";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		gpio = <&pio 5 4 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-always-on;
		regulator-boot-on;
	};
};

/* Hardware buttons */
/ {
	gpio-keys {
		compatible = "gpio-keys";

		volume-down {
			label = "Volume Down";
			linux,code = <114>; /* KEY_VOLUMEDOWN */
			gpios = <&pio 6 0 GPIO_ACTIVE_LOW>; /* PG0 */
		};
		volume-up {
			label = "Volume Up";
			linux,code = <115>; /* KEY_VOLUMEUP */
			gpios = <&pio 6 11 GPIO_ACTIVE_LOW>; /* PG11 */
		};
		action {
			label = "Action";
			linux,code = <28>; /* KEY_ENTER */
			gpios = <&pio 1 2 GPIO_ACTIVE_LOW>; /* PB2 */
		};
	};
};

/* Audio codec — ALSA manages clocks and codec registers */
&codec {
	allwinner,pa-gpios = <&pio 3 24 GPIO_ACTIVE_HIGH>;
	status = "okay";
};

/* EVERYTHING BELOW IS EXPLICITLY DISABLED */

/* LCD/TCON — MUST be disabled to keep PD23 as GPIO for LED power */
&tcon0 {
	status = "disabled";
};

&be0 {
	status = "disabled";
};

&fe0 {
	status = "disabled";
};
